    <webLinks>
        <fullName>Mass_Delete_Records</fullName>
        <availability>online</availability>
        <description>Mass delete records</description>
        <displayType>massActionButton</displayType>
        <linkType>page</linkType>
        <masterLabel>Mass Delete</masterLabel>
        <openType>replace</openType>
        <page>Mass_Delete_Opportunity</page>
        <protected>false</protected>
        <requireRowSelection>true</requireRowSelection>
    </webLinks>
    <webLinks>
        <fullName>SBQQ__Amend_Assets</fullName>
        <availability>online</availability>
        <displayType>button</displayType>
        <encodingKey>UTF-8</encodingKey>
        <linkType>url</linkType>
        <masterLabel>Amend Assets</masterLabel>
        <openType>replace</openType>
        <protected>false</protected>
        <url>/apex/SBQQ__AssetSelector?accountId={!Opportunity.AccountId}&amp;oppId={!Opportunity.Id}</url>
    </webLinks>
    <webLinks>
        <fullName>SBQQ__Amend_Contract</fullName>
        <availability>online</availability>
