    <deploymentStatus>Deployed</deploymentStatus>
    <deprecated>false</deprecated>
    <description>A specification for the deletion of an object&apos;s records as part of a demo cleanup.</description>
    <enableActivities>false</enableActivities>
    <enableBulkApi>true</enableBulkApi>
    <enableFeeds>false</enableFeeds>
    <enableHistory>false</enableHistory>
    <enableLicensing>false</enableLicensing>
    <enableReports>false</enableReports>
    <enableSearch>true</enableSearch>
    <enableSharing>true</enableSharing>
    <enableStreamingApi>true</enableStreamingApi>
    <externalSharingModel>Private</externalSharingModel>
    <fields>
        <fullName>Active__c</fullName>
        <defaultValue>true</defaultValue>
        <deprecated>false</deprecated>
        <description>Checked if this item should be included in the list of tasks.</description>
        <inlineHelpText>Checked if this item should be included in the list of tasks.</inlineHelpText>
        <label>Active</label>
        <trackTrending>false</trackTrending>
        <type>Checkbox</type>
    </fields>
    <fields>
        <fullName>Apex_Class_Name__c</fullName>
        <deprecated>false</deprecated>
        <description>The name of the Apex class to execute. The class must implement the DemoCleanupApexItem interface.</description>
        <externalId>false</externalId>
        <inlineHelpText>The name of the Apex class to execute. The class must implement the DemoCleanupApexItem interface.</inlineHelpText>
        <label>Apex Class Name</label>
        <length>255</length>
        <required>false</required>
        <trackTrending>false</trackTrending>
        <type>Text</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>Description__c</fullName>
        <deprecated>false</deprecated>
        <description>A description of the demo cleanup item, for example, &quot;Delete all records that are not custom-crafted for the demo scenario&quot;.</description>
        <externalId>false</externalId>
        <inlineHelpText>A description of the demo cleanup item, for example, &quot;Delete all records that are not custom-crafted for the demo scenario&quot;.</inlineHelpText>
        <label>Description</label>
        <length>255</length>
        <required>false</required>
        <trackTrending>false</trackTrending>
        <type>Text</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>Flow_API_Name__c</fullName>
        <deprecated>false</deprecated>
        <description>API name of the autolaunched flow to execute.</description>
        <externalId>false</externalId>
        <inlineHelpText>API name of the autolaunched flow to execute.</inlineHelpText>
        <label>Flow API Name</label>
        <length>255</length>
        <required>false</required>
        <trackTrending>false</trackTrending>
        <type>Text</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>Object_API_Name__c</fullName>
        <deprecated>false</deprecated>
        <description>API Name of the object whose records are to be deleted.</description>
        <externalId>false</externalId>
        <inlineHelpText>API Name of the object whose records are to be deleted.</inlineHelpText>
        <label>Object API Name</label>
        <length>255</length>
        <required>false</required>
        <trackTrending>false</trackTrending>
        <type>Text</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>Order__c</fullName>
        <deprecated>false</deprecated>
        <description>The order in which this Demo Cleanup Task will be executed.</description>
        <externalId>false</externalId>
        <inlineHelpText>The order in which this Demo Cleanup Task will be executed.</inlineHelpText>
        <label>Order</label>
        <precision>5</precision>
        <required>false</required>
        <scale>0</scale>
        <trackTrending>false</trackTrending>
        <type>Number</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>Permanently_Delete__c</fullName>
        <defaultValue>false</defaultValue>
        <deprecated>false</deprecated>
        <description>Checked if records of this object should bypass the recycle bin and be permanently deleted.</description>
        <inlineHelpText>Checked if records of this object should bypass the recycle bin and be permanently deleted.</inlineHelpText>
        <label>Permanently Delete</label>
        <trackTrending>false</trackTrending>
        <type>Checkbox</type>
    </fields>
    <fields>
        <fullName>SOQL_WHERE_Clause__c</fullName>
        <deprecated>false</deprecated>
        <description>A SOQL WHERE clause expression (without the &quot;WHERE&quot;) that evaluates to &quot;true&quot; if a record should be deleted, for example, &quot;Hand_Crafted_for_Demo_Scenario__c = false&quot;. Leave blank if all records of this object are to be deleted.</description>
        <inlineHelpText>A SOQL WHERE clause expression (without the &quot;WHERE&quot;) that evaluates to &quot;true&quot; if a record should be deleted, for example, &quot;Hand_Crafted_for_Demo_Scenario__c = false&quot;. Leave blank if all records of this object are to be deleted.</inlineHelpText>
        <label>SOQL WHERE Clause</label>
        <length>32768</length>
        <trackTrending>false</trackTrending>
        <type>LongTextArea</type>
        <visibleLines>3</visibleLines>
    </fields>
    <label>Demo Cleanup Task</label>
    <listViews>
        <fullName>All</fullName>
        <columns>Active__c</columns>
        <columns>NAME</columns>
        <columns>Order__c</columns>
        <columns>RECORDTYPE</columns>
        <columns>Description__c</columns>
        <columns>Object_API_Name__c</columns>
