        <displayFormat>DCT-{0000}</displayFormat>
        <label>Demo Cleanup Task ID</label>
        <type>AutoNumber</type>
    </nameField>
    <pluralLabel>Demo Cleanup Tasks</pluralLabel>
    <recordTypes>
        <fullName>Apex_Cleanup_Task</fullName>
        <active>true</active>
        <description>Demo cleanup task is an Apex class specification.</description>
        <label>Apex Cleanup Task</label>
    </recordTypes>
    <recordTypes>
        <fullName>Flow_Cleanup_Task</fullName>
        <active>true</active>
        <description>Demo cleanup task is an autolaunched flow.</description>
        <label>Flow Cleanup Task</label>
    </recordTypes>
    <recordTypes>
        <fullName>SOQL_Cleanup_Task</fullName>
        <active>true</active>
        <description>Demo cleanup task is based on a SOQL query.</description>
        <label>SOQL Cleanup Task</label>
    </recordTypes>
    <searchLayouts/>
    <sharingModel>ReadWrite</sharingModel>
    <validationRules>
        <fullName>For_Apex_Task_Apex_Class_Name_Required</fullName>
        <active>true</active>
        <description>For an Apex Demo Cleanup Task, the Apex class name is required.</description>
        <errorConditionFormula>RecordType.Name == &apos;Apex Cleanup Item&apos; &amp;&amp; ISBLANK(Apex_Class_Name__c)</errorConditionFormula>
        <errorDisplayField>Apex_Class_Name__c</errorDisplayField>
        <errorMessage>For an Apex cleanup task, the Apex class name must be specified.</errorMessage>
    </validationRules>
    <validationRules>
        <fullName>For_Flow_Task_Flow_Name_Is_Required</fullName>
        <active>true</active>
        <description>Each flow Demo Cleanup Task must include the flow name.</description>
        <errorConditionFormula>RecordType.Name == &quot;Flow Cleanup Item&quot; &amp;&amp; ISBLANK(Flow_API_Name__c)</errorConditionFormula>
        <errorDisplayField>Flow_API_Name__c</errorDisplayField>
        <errorMessage>For a flow cleanup task, the flow name must be specified.</errorMessage>
    </validationRules>
    <validationRules>
        <fullName>For_SOQL_Task_Object_Name_Required</fullName>
        <active>true</active>
        <description>For a SOQL cleanup task, an object API name is required</description>
        <errorConditionFormula>RecordType.Name == &apos;SOQL Cleanup Item&apos; &amp;&amp; ISBLANK(Object_API_Name__c)</errorConditionFormula>
        <errorDisplayField>Object_API_Name__c</errorDisplayField>
        <errorMessage>For a SOQL cleanup task, the object API name must be specified.</errorMessage>
    </validationRules>
    <visibility>Public</visibility>
</CustomObject>
