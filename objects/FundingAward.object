    <compactLayoutAssignment>SYSTEM</compactLayoutAssignment>
    <enableFeeds>false</enableFeeds>
    <externalSharingModel>Private</externalSharingModel>
    <fields>
        <fullName>Amount</fullName>
        <trackHistory>false</trackHistory>
    </fields>
    <fields>
        <fullName>ApplicationFormId</fullName>
        <trackHistory>false</trackHistory>
        <type>Lookup</type>
    </fields>
    <fields>
        <fullName>AwardeeId</fullName>
        <trackHistory>false</trackHistory>
        <type>Lookup</type>
    </fields>
    <fields>
        <fullName>Awardee_Name__c</fullName>
        <externalId>false</externalId>
        <formula>IndividualApplication.Account.Name</formula>
        <formulaTreatBlanksAs>BlankAsZero</formulaTreatBlanksAs>
        <label>Awardee Name</label>
        <required>false</required>
        <trackHistory>false</trackHistory>
        <type>Text</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>BudgetId</fullName>
        <trackHistory>false</trackHistory>
        <type>Lookup</type>
    </fields>
    <fields>
        <fullName>ContactId</fullName>
        <trackHistory>false</trackHistory>
        <type>Lookup</type>
    </fields>
    <fields>
        <fullName>ContractId</fullName>
        <trackHistory>false</trackHistory>
        <type>Lookup</type>
    </fields>
    <fields>
        <fullName>CurrencyIsoCode</fullName>
        <trackHistory>false</trackHistory>
    </fields>
    <fields>
        <fullName>DecisionDate</fullName>
        <trackHistory>false</trackHistory>
    </fields>
    <fields>
        <fullName>EndDate</fullName>
        <trackHistory>false</trackHistory>
    </fields>
    <fields>
        <fullName>FundingOpportunityId</fullName>
        <trackHistory>false</trackHistory>
        <type>Lookup</type>
    </fields>
    <fields>
        <fullName>IndividualApplicationId</fullName>
        <trackHistory>false</trackHistory>
        <type>Lookup</type>
    </fields>
    <fields>
        <fullName>Name</fullName>
        <trackHistory>false</trackHistory>
    </fields>
    <fields>
        <fullName>OwnerId</fullName>
        <trackHistory>false</trackHistory>
        <type>Lookup</type>
    </fields>
    <fields>
        <fullName>ParentFundingAwardId</fullName>
        <trackHistory>false</trackHistory>
        <type>Hierarchy</type>
    </fields>
    <fields>
        <fullName>ProgramId</fullName>
        <trackHistory>false</trackHistory>
        <type>Lookup</type>
    </fields>
    <fields>
        <fullName>StartDate</fullName>
        <trackHistory>false</trackHistory>
    </fields>
    <fields>
        <fullName>Status</fullName>
        <trackHistory>false</trackHistory>
        <type>Picklist</type>
    </fields>
    <fields>
        <fullName>gps_Available_for_Disbursement__c</fullName>
        <formula>Amount - gps_Unpaid_Disbursements__c - gps_Paid_Disbursements__c</formula>
        <formulaTreatBlanksAs>BlankAsZero</formulaTreatBlanksAs>
        <label>Available for Disbursement</label>
        <precision>18</precision>
        <required>false</required>
        <scale>2</scale>
        <trackHistory>false</trackHistory>
        <type>Currency</type>
    </fields>
    <fields>
        <fullName>gps_Awarded_Amount__c</fullName>
        <formula>Amount</formula>
        <formulaTreatBlanksAs>BlankAsZero</formulaTreatBlanksAs>
        <label>Awarded Amount</label>
        <precision>18</precision>
        <required>false</required>
        <scale>2</scale>
        <trackHistory>false</trackHistory>
        <type>Currency</type>
    </fields>
    <fields>
        <fullName>gps_ContractDescription__c</fullName>
        <externalId>false</externalId>
        <formula>&quot;Contract details for &quot; &amp; Name &amp; &quot; under &quot; &amp;  FundingOpportunity.Name</formula>
        <label>Contract Description</label>
        <required>false</required>
        <trackHistory>false</trackHistory>
        <type>Text</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>gps_ContractName__c</fullName>
        <externalId>false</externalId>
        <formula>left(Name &amp; &quot; under &quot; &amp;  FundingOpportunity.Name,80)</formula>
        <formulaTreatBlanksAs>BlankAsZero</formulaTreatBlanksAs>
        <label>Contract Name</label>
        <required>false</required>
        <trackHistory>false</trackHistory>
        <type>Text</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>gps_Paid_Disbursements__c</fullName>
        <label>Paid Disbursements</label>
        <summarizedField>FundingDisbursement.Amount</summarizedField>
        <summaryFilterItems>
            <field>FundingDisbursement.Status</field>
            <operation>equals</operation>
            <value>Paid</value>
        </summaryFilterItems>
        <summaryForeignKey>FundingDisbursement.FundingAwardId</summaryForeignKey>
        <summaryOperation>sum</summaryOperation>
        <trackHistory>false</trackHistory>
        <type>Summary</type>
    </fields>
    <fields>
        <fullName>gps_Total_Cancelled__c</fullName>
        <label>Total Cancelled</label>
        <summarizedField>FundingDisbursement.Amount</summarizedField>
        <summaryFilterItems>
            <field>FundingDisbursement.Status</field>
            <operation>equals</operation>
            <value>Cancelled</value>
        </summaryFilterItems>
        <summaryForeignKey>FundingDisbursement.FundingAwardId</summaryForeignKey>
        <summaryOperation>sum</summaryOperation>
        <trackHistory>false</trackHistory>
        <type>Summary</type>
    </fields>
    <fields>
        <fullName>gps_Unpaid_Disbursements__c</fullName>
        <label>Unpaid Disbursements</label>
        <summarizedField>FundingDisbursement.Amount</summarizedField>
        <summaryFilterItems>
            <field>FundingDisbursement.Status</field>
            <operation>notEqual</operation>
            <value>Paid, Cancelled</value>
        </summaryFilterItems>
        <summaryForeignKey>FundingDisbursement.FundingAwardId</summaryForeignKey>
        <summaryOperation>sum</summaryOperation>
        <trackHistory>false</trackHistory>
        <type>Summary</type>
    </fields>
    <listViews>
        <fullName>All_FundingAwards</fullName>
        <filterScope>Everything</filterScope>
        <label>All Funding Awards</label>
    </listViews>
    <searchLayouts>
        <customTabListAdditionalFields>LastModifiedBy</customTabListAdditionalFields>
        <customTabListAdditionalFields>LastModifiedDate</customTabListAdditionalFields>
        <lookupDialogsAdditionalFields>LastModifiedBy</lookupDialogsAdditionalFields>
        <lookupDialogsAdditionalFields>LastModifiedDate</lookupDialogsAdditionalFields>
        <lookupPhoneDialogsAdditionalFields>LastModifiedBy</lookupPhoneDialogsAdditionalFields>
        <lookupPhoneDialogsAdditionalFields>LastModifiedDate</lookupPhoneDialogsAdditionalFields>
        <searchResultsAdditionalFields>LastModifiedBy</searchResultsAdditionalFields>
        <searchResultsAdditionalFields>LastModifiedDate</searchResultsAdditionalFields>
    </searchLayouts>
    <sharingModel>Private</sharingModel>
</CustomObject>
