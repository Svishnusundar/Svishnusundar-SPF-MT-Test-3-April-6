        <type>Picklist</type>
        <valueSet>
            <restricted>true</restricted>
            <valueSetDefinition>
                <sorted>false</sorted>
                <value>
                    <fullName>Negative</fullName>
                    <default>false</default>
                    <label>Negative</label>
                </value>
                <value>
                    <fullName>Positive</fullName>
                    <default>false</default>
                    <label>Positive</label>
                </value>
            </valueSetDefinition>
        </valueSet>
    </fields>
