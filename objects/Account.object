        <formula>IMAGE(&apos;https://qnextgen.s3.us-west-1.amazonaws.com/logos/Icon_star.png&apos;, &apos;&apos;,0,0) &amp;
IMAGE(IF (SDO_Value__c &gt; 0, &apos;https://qnextgen.s3.us-west-1.amazonaws.com/logos/Icon_star.png&apos;, &apos;https://qnextgen.s3.us-west-1.amazonaws.com/logos/Icon-+Star+Off.png&apos;),&apos;&apos;,22,22) &amp;&quot;&quot;&amp; 
IMAGE(IF (SDO_Value__c &gt; 1, &apos;https://qnextgen.s3.us-west-1.amazonaws.com/logos/Icon_star.png&apos;, &apos;https://qnextgen.s3.us-west-1.amazonaws.com/logos/Icon-+Star+Off.png&apos;),&apos;&apos;,22,22) &amp;&quot;&quot;&amp; 
IMAGE(IF (SDO_Value__c &gt; 2, &apos;https://qnextgen.s3.us-west-1.amazonaws.com/logos/Icon_star.png&apos;, &apos;https://qnextgen.s3.us-west-1.amazonaws.com/logos/Icon-+Star+Off.png&apos;),&apos;&apos;,22,22) &amp;&quot;&quot;&amp; 
IMAGE(IF (SDO_Value__c &gt; 3, &apos;https://qnextgen.s3.us-west-1.amazonaws.com/logos/Icon_star.png&apos;, &apos;https://qnextgen.s3.us-west-1.amazonaws.com/logos/Icon-+Star+Off.png&apos;),&apos;&apos;,22,22) &amp;&quot;&quot;&amp; 
IMAGE(IF (SDO_Value__c &gt; 4, &apos;https://qnextgen.s3.us-west-1.amazonaws.com/logos/Icon_star.png&apos;, &apos;https://qnextgen.s3.us-west-1.amazonaws.com/logos/Icon-+Star+Off.png&apos;),&apos;&apos;,22,22)</formula>
        <formulaTreatBlanksAs>BlankAsZero</formulaTreatBlanksAs>
