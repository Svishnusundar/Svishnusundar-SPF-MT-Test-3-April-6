    <fields>
        <fullName>SDO_SPM_Area_Auto_Calc__c</fullName>
        <description>SPM Sales Planning demo field 9-5-23 Aaron Bendickson</description>
        <externalId>false</externalId>
        <formula>CASE( BillingState ,&quot;AL&quot;, &quot;Southeast&quot;,&quot;AK&quot;, &quot;Northwest&quot;,&quot;AZ&quot;, &quot;Southwest&quot;,&quot;AR&quot;, &quot;South&quot;,&quot;CA&quot;, &quot;Southwest&quot;,&quot;CO&quot;, &quot;Midwest&quot;,&quot;CT&quot;, &quot;Northeast&quot;,&quot;DE&quot;, &quot;Northeast&quot;,&quot;DC&quot;, &quot;Northeast&quot;,&quot;FL&quot;, &quot;Southeast&quot;,&quot;GA&quot;, &quot;Southeast&quot;,&quot;HI&quot;, &quot;Southwest&quot;,&quot;ID&quot;, &quot;Northwest&quot;,&quot;IL&quot;, &quot;Northeast&quot;,&quot;IN&quot;, &quot;Northeast&quot;,&quot;IA&quot;, &quot;Midwest&quot;,&quot;KS&quot;, &quot;Midwest&quot;,&quot;KY&quot;, &quot;Northeast&quot;,&quot;LA&quot;, &quot;South&quot;,&quot;ME&quot;, &quot;Northeast&quot;,&quot;MD&quot;, &quot;Northeast&quot;,&quot;MA&quot;, &quot;Northeast&quot;,&quot;MI&quot;, &quot;Northeast&quot;,&quot;MN&quot;, &quot;Midwest&quot;,&quot;MS&quot;, &quot;Southeast&quot;,&quot;MO&quot;, &quot;Midwest&quot;,&quot;MT&quot;, &quot;Northwest&quot;,&quot;NE&quot;, &quot;Midwest&quot;,&quot;NV&quot;, &quot;Southwest&quot;,&quot;NH&quot;, &quot;Northeast&quot;,&quot;NJ&quot;, &quot;Northeast&quot;,&quot;NM&quot;, &quot;Southwest&quot;,&quot;NY&quot;, &quot;Northeast&quot;,&quot;NC&quot;, &quot;Southeast&quot;,&quot;ND&quot;, &quot;Midwest&quot;,&quot;OH&quot;, &quot;Northeast&quot;,&quot;OK&quot;, &quot;South&quot;,&quot;OR&quot;, &quot;Northwest&quot;,&quot;PA&quot;, &quot;Northeast&quot;,&quot;RI&quot;, &quot;Northeast&quot;,&quot;SC&quot;, &quot;Southeast&quot;,&quot;SD&quot;, &quot;Midwest&quot;,&quot;TN&quot;, &quot;Southeast&quot;,&quot;TX&quot;, &quot;South&quot;,&quot;UT&quot;, &quot;Southwest&quot;,&quot;VT&quot;, &quot;Northeast&quot;,&quot;VA&quot;, &quot;Northeast&quot;,&quot;WA&quot;, &quot;Northwest&quot;,&quot;WV&quot;, &quot;Northeast&quot;,&quot;WI&quot;, &quot;Northeast&quot;,&quot;WY&quot;, &quot;Northwest&quot;,&quot;AB&quot;, &quot;West&quot;,&quot;BC&quot;, &quot;West&quot;,&quot;MB&quot;, &quot;Central&quot;,&quot;NB&quot;, &quot;East&quot;,&quot;NL&quot;, &quot;East&quot;,&quot;NT&quot;, &quot;North&quot;,&quot;NS&quot;, &quot;East&quot;,&quot;NU&quot;, &quot;North&quot;,&quot;ON&quot;, &quot;Central&quot;,&quot;PE&quot;, &quot;East&quot;,&quot;QC&quot;, &quot;East&quot;,&quot;SK&quot;, &quot;Central&quot;,&quot;YT&quot;, &quot;North&quot;,&quot;&quot;)</formula>
        <formulaTreatBlanksAs>BlankAsZero</formulaTreatBlanksAs>
        <inlineHelpText>Auto-calculated Area based on the Billing State value.</inlineHelpText>
        <label>Area (Auto-Calc)</label>
        <required>false</required>
        <trackHistory>false</trackHistory>
        <type>Text</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>SDO_SPM_Area_Formatted__c</fullName>
        <description>SPM Sales Planning demo field 9-5-23 Aaron Bendickson</description>
        <externalId>false</externalId>
        <formula>SDO_SPM_Region_Auto_Calc__c + &quot;-&quot; + SDO_SPM_Segment_Auto_Calc__c + &quot;-&quot; + SDO_SPM_Area_Auto_Calc__c</formula>
        <formulaTreatBlanksAs>BlankAsZero</formulaTreatBlanksAs>
        <inlineHelpText>Combines Region, Segment and Area to create a formatted Area name.</inlineHelpText>
        <label>Area (Formatted)</label>
        <required>false</required>
        <trackHistory>false</trackHistory>
        <type>Text</type>
        <unique>false</unique>
    </fields>
