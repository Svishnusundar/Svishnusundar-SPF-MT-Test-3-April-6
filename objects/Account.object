        <description>SPM Sales Planning demo field 9-5-23 Aaron Bendickson</description>
        <externalId>false</externalId>
        <formula>CASE( BillingCountry ,&quot;USA&quot;, &quot;USA&quot;,&quot;United States&quot;, &quot;USA&quot;,&quot;US&quot;, &quot;USA&quot;,&quot;Canada&quot;, &quot;CAN&quot;,&quot;CAN&quot;, &quot;CAN&quot;,&quot;CA&quot;, &quot;CA&quot;,&quot;&quot;)</formula>
        <formulaTreatBlanksAs>BlankAsZero</formulaTreatBlanksAs>
        <label>Region (Auto-Calc)</label>
        <required>false</required>
        <trackHistory>false</trackHistory>
        <type>Text</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>SDO_SPM_Segment_Auto_Calc__c</fullName>
        <description>SDO SPM Sales Planning demo field created by Aaron Bendickson 9-11-2023</description>
        <externalId>false</externalId>
        <formula>IF( AnnualRevenue &lt;= 3000000, &quot;SMB&quot;,
IF( AND( AnnualRevenue &gt; 3000000, AnnualRevenue &lt;= 5000000), &quot;Commercial&quot;,
IF( AnnualRevenue &gt; 5000000, &quot;Enterprise&quot;, &quot;SMB&quot;)))</formula>
        <formulaTreatBlanksAs>BlankAsZero</formulaTreatBlanksAs>
        <label>Segment (Auto-Calc)</label>
        <required>false</required>
        <trackHistory>false</trackHistory>
        <type>Text</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>SDO_SPM_Segment_Formatted__c</fullName>
        <description>SPM Sales Planning demo field 9-5-23 Aaron Bendickson</description>
        <externalId>false</externalId>
        <formula>SDO_SPM_Region_Auto_Calc__c + &quot;-&quot; + SDO_SPM_Segment_Auto_Calc__c</formula>
        <formulaTreatBlanksAs>BlankAsZero</formulaTreatBlanksAs>
        <inlineHelpText>Combines Region and Segment to create a formatted Segment name</inlineHelpText>
        <label>Segment (Formatted)</label>
        <required>false</required>
        <trackHistory>false</trackHistory>
        <type>Text</type>
