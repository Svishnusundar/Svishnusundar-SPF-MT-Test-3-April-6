    <fields>
        <fullName>Number_Notation__c</fullName>
        <description>Based on Intl.NumberFormat() javascript object standard values to determine how numbers are rendered</description>
        <fieldManageability>DeveloperControlled</fieldManageability>
        <inlineHelpText>E.g. &quot;standard&quot; = 3,500,000; &quot;scientific&quot; = 3.5E6; &quot;compact&quot; = 3.5M. Applies only to &apos;decimal&apos; metric formats</inlineHelpText>
        <label>Number Notation</label>
        <required>false</required>
        <type>Picklist</type>
        <valueSet>
            <restricted>true</restricted>
            <valueSetDefinition>
                <sorted>false</sorted>
                <value>
                    <fullName>standard</fullName>
                    <default>true</default>
                    <label>standard</label>
                </value>
                <value>
                    <fullName>scientific</fullName>
                    <default>false</default>
                    <label>scientific</label>
                </value>
                <value>
                    <fullName>compact</fullName>
                    <default>false</default>
                    <label>compact</label>
                </value>
            </valueSetDefinition>
        </valueSet>
    </fields>
    <fields>
        <fullName>Object_API_Name__c</fullName>
        <description>Object API name of the record metrics</description>
        <externalId>false</externalId>
        <fieldManageability>DeveloperControlled</fieldManageability>
        <inlineHelpText>If using a custom object, include the __c suffix. E.g. My_Custom_Object__c</inlineHelpText>
        <label>Object API Name</label>
        <length>50</length>
        <required>true</required>
        <type>Text</type>
        <unique>false</unique>
    </fields>
    <label>Key Metrics Setting</label>
    <pluralLabel>Key Metrics Settings</pluralLabel>
    <visibility>Public</visibility>
</CustomObject>
