        <fieldManageability>DeveloperControlled</fieldManageability>
        <label>Metric 3 Label</label>
        <length>50</length>
        <required>false</required>
        <type>Text</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>Metric_4_API_Name__c</fullName>
        <description>API Name of the field on the object for metric 2</description>
        <externalId>false</externalId>
        <fieldManageability>DeveloperControlled</fieldManageability>
        <label>Metric 4 API Name</label>
        <length>50</length>
        <required>false</required>
        <type>Text</type>
        <unique>false</unique>
    </fields>
    <fields>
