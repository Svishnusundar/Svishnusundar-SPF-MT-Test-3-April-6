    <validationRules>
        <fullName>FSLDemoTools_Fields</fullName>
        <active>false</active>
        <errorConditionFormula>OR( ISCHANGED(  FSLDemoTools_Original_Geolocation__Latitude__s  ),ISCHANGED(   FSLDemoTools_Original_Geolocation__Longitude__s   )   , ISCHANGED(  FSLDemoTools_Original_Name__c  )  , ISCHANGED(  FSLDemoTools_Original_Timezone__c  )  )</errorConditionFormula>
        <errorMessage>You can&apos;t edit the FSLDemoTools Master data fields</errorMessage>
    </validationRules>
