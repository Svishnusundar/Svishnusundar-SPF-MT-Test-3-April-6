    <compactLayoutAssignment>SYSTEM</compactLayoutAssignment>
    <enableDataTranslation>true</enableDataTranslation>
    <enableFeeds>false</enableFeeds>
    <externalSharingModel>ReadWrite</externalSharingModel>
    <fields>
        <fullName>Address</fullName>
        <trackHistory>false</trackHistory>
    </fields>
    <fields>
        <fullName>AvgTravelTime</fullName>
        <inlineHelpText>Enter the average travel time for this service territory. The value is added to the Work Capacity Usage for each scheduled service appointment in the service territory.</inlineHelpText>
        <trackHistory>false</trackHistory>
    </fields>
    <fields>
        <fullName>Description</fullName>
        <trackHistory>false</trackHistory>
        <translateData>true</translateData>
    </fields>
    <fields>
        <fullName>External_ID__c</fullName>
        <caseSensitive>true</caseSensitive>
        <externalId>true</externalId>
        <label>External ID</label>
        <length>255</length>
        <required>false</required>
        <trackHistory>false</trackHistory>
        <type>Text</type>
        <unique>true</unique>
    </fields>
    <fields>
        <fullName>FSLDemoTools_Original_Geolocation__c</fullName>
        <displayLocationInDecimal>true</displayLocationInDecimal>
        <label>FSLDemoTools Original Geolocation</label>
        <required>false</required>
        <scale>6</scale>
        <trackHistory>false</trackHistory>
        <type>Location</type>
    </fields>
    <fields>
        <fullName>FSLDemoTools_Original_Name__c</fullName>
        <externalId>false</externalId>
