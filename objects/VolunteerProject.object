        <description>Number of volunteers that have registered for this volunteer project. This is an auto-calculated field.</description>
        <externalId>false</externalId>
        <inlineHelpText>Number of volunteers that have registered for this volunteer project. This is an auto-calculated field.</inlineHelpText>
        <label>Volunteers Registered</label>
        <precision>18</precision>
        <required>false</required>
        <scale>0</scale>
        <trackHistory>false</trackHistory>
        <type>Number</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>PublicSector__VolunteersStillNeeded__c</fullName>
        <deprecated>false</deprecated>
        <description>Number of volunteers that are still needed for this volunteer project. This is an auto-calculated field.</description>
        <externalId>false</externalId>
        <formula>VolunteersRequired  -  PublicSector__VolunteersRegistered__c</formula>
        <formulaTreatBlanksAs>BlankAsZero</formulaTreatBlanksAs>
        <inlineHelpText>Number of volunteers that are still needed for this volunteer project. This is an auto-calculated field.</inlineHelpText>
