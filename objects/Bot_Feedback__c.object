    <allowInChatterGroups>false</allowInChatterGroups>
    <compactLayoutAssignment>SYSTEM</compactLayoutAssignment>
    <deploymentStatus>Deployed</deploymentStatus>
    <enableActivities>true</enableActivities>
    <enableBulkApi>true</enableBulkApi>
    <enableFeeds>false</enableFeeds>
    <enableHistory>false</enableHistory>
    <enableLicensing>false</enableLicensing>
    <enableReports>true</enableReports>
    <enableSearch>true</enableSearch>
    <enableSharing>true</enableSharing>
    <enableStreamingApi>true</enableStreamingApi>
    <externalSharingModel>Private</externalSharingModel>
    <fields>
        <fullName>Channel__c</fullName>
        <description>Determines the channel the bot conversation took place on.
By default only Chat is included, update this for new channels as you add the bot to them.</description>
        <inlineHelpText>The channel the bot conversation took place on.</inlineHelpText>
        <label>Channel</label>
        <required>false</required>
        <trackTrending>false</trackTrending>
        <type>Picklist</type>
        <valueSet>
            <restricted>true</restricted>
            <valueSetDefinition>
                <sorted>false</sorted>
                <value>
                    <fullName>Chat</fullName>
                    <default>false</default>
                    <label>Chat</label>
                </value>
            </valueSetDefinition>
        </valueSet>
    </fields>
    <fields>
        <fullName>Chat_Transcript__c</fullName>
        <deleteConstraint>SetNull</deleteConstraint>
        <description>Chat that this bot survey is related to</description>
        <inlineHelpText>Chat that this bot survey is related to</inlineHelpText>
        <label>Chat Transcript</label>
        <referenceTo>LiveChatTranscript</referenceTo>
        <relationshipLabel>Bot Feedback</relationshipLabel>
        <relationshipName>Bot_Feedback</relationshipName>
        <required>false</required>
        <trackTrending>false</trackTrending>
        <type>Lookup</type>
    </fields>
    <fields>
        <fullName>Survey_Comment__c</fullName>
        <description>Comments relating to their choice of positive or negative for the bot session</description>
        <inlineHelpText>Comments relating to their choice of positive or negative for the bot session</inlineHelpText>
        <label>Survey Comment</label>
        <required>false</required>
        <trackTrending>false</trackTrending>
        <type>TextArea</type>
    </fields>
    <fields>
        <fullName>Survey_Positive__c</fullName>
        <defaultValue>false</defaultValue>
        <description>Was this a positive interaction or not?</description>
        <inlineHelpText>Was this a positive interaction or not? True for positive, False for negative/neutral</inlineHelpText>
        <label>Survey Positive</label>
        <trackTrending>false</trackTrending>
        <type>Checkbox</type>
    </fields>
    <label>Bot Feedback</label>
    <listViews>
        <fullName>All</fullName>
        <columns>NAME</columns>
        <columns>CREATED_DATE</columns>
        <columns>Channel__c</columns>
        <columns>Survey_Positive__c</columns>
        <columns>Survey_Comment__c</columns>
        <columns>Chat_Transcript__c</columns>
        <filterScope>Everything</filterScope>
        <label>All</label>
    </listViews>
    <nameField>
        <displayFormat>BF-{0000}</displayFormat>
        <label>Bot Feedback Name</label>
        <type>AutoNumber</type>
    </nameField>
    <pluralLabel>Bot Feedback</pluralLabel>
    <searchLayouts/>
    <sharingModel>ReadWrite</sharingModel>
    <visibility>Public</visibility>
</CustomObject>
