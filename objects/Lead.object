    <fields>
        <fullName>SDO_Sales_Know_Decision_Maker__c</fullName>
        <defaultValue>false</defaultValue>
        <description>What; Decision Maker Field</description>
        <label>Decision Maker</label>
        <trackFeedHistory>false</trackFeedHistory>
        <trackHistory>true</trackHistory>
        <type>Checkbox</type>
    </fields>
    <fields>
        <fullName>SDO_Sales_Lead_Quality__c</fullName>
        <externalId>false</externalId>
        <formula>IMAGE(&apos;/servlet/servlet.FileDownload?file=&apos;&amp; IF (SDO_Sales_Lead_Total__c &gt; 0, &apos;015Hu000005vDkH&apos;, &apos;015Hu000005vDkI&apos;),&apos;&apos;,24,22) &amp;&quot;&quot;&amp;
IMAGE(&apos;/servlet/servlet.FileDownload?file=&apos;&amp; IF (SDO_Sales_Lead_Total__c &gt; 5, &apos;015Hu000005vDkH&apos;, &apos;015Hu000005vDkI&apos;),&apos;&apos;,24,22) &amp;&quot;&quot;&amp;
IMAGE(&apos;/servlet/servlet.FileDownload?file=&apos;&amp; IF (SDO_Sales_Lead_Total__c &gt; 10, &apos;015Hu000005vDkH&apos;, &apos;015Hu000005vDkI&apos;),&apos;&apos;,24,22) &amp;&quot;&quot;&amp;
IMAGE(&apos;/servlet/servlet.FileDownload?file=&apos;&amp; IF (SDO_Sales_Lead_Total__c &gt; 15, &apos;015Hu000005vDkH&apos;, &apos;015Hu000005vDkI&apos;),&apos;&apos;,24,22)</formula>
        <formulaTreatBlanksAs>BlankAsZero</formulaTreatBlanksAs>
        <label>Lead Quality</label>
        <required>false</required>
        <trackHistory>false</trackHistory>
        <type>Text</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>SDO_Sales_Lead_Total__c</fullName>
        <description>What: Formula to calculate total score from score fields.</description>
        <externalId>false</externalId>
        <formula>Score1__c + Score2__c  +Score3__c + Score4__c</formula>
        <formulaTreatBlanksAs>BlankAsZero</formulaTreatBlanksAs>
        <label>Total Score</label>
        <precision>18</precision>
        <required>false</required>
        <scale>2</scale>
        <trackHistory>false</trackHistory>
        <type>Number</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>SDO_Sales_Product_Interest__c</fullName>
        <description>What: What products are they interested in.</description>
        <label>Product Interest</label>
        <required>false</required>
        <trackFeedHistory>false</trackFeedHistory>
        <trackHistory>true</trackHistory>
        <type>Picklist</type>
        <valueSet>
            <restricted>true</restricted>
            <valueSetDefinition>
                <sorted>false</sorted>
                <value>
                    <fullName>Products</fullName>
                    <default>false</default>
                    <label>Products</label>
                </value>
                <value>
                    <fullName>Services</fullName>
                    <default>false</default>
                    <label>Services</label>
                </value>
                <value>
                    <fullName>Support</fullName>
                    <default>false</default>
                    <label>Support</label>
                </value>
                <value>
                    <fullName>Consulting</fullName>
                    <default>false</default>
                    <label>Consulting</label>
                </value>
                <value>
                    <fullName>Compliance</fullName>
                    <default>false</default>
                    <label>Compliance</label>
                </value>
                <value>
                    <fullName>Other</fullName>
                    <default>false</default>
                    <label>Other</label>
                </value>
            </valueSetDefinition>
        </valueSet>
    </fields>
    <fields>
        <fullName>SDO_Sales_Project_Defined__c</fullName>
        <defaultValue>false</defaultValue>
        <description>What: Project Defined Field used in page layouts.</description>
        <label>Project Defined</label>
        <trackFeedHistory>false</trackFeedHistory>
        <trackHistory>false</trackHistory>
        <type>Checkbox</type>
    </fields>
    <fields>
        <fullName>SMS_Message__c</fullName>
        <description>The content of the SMS message to send out via a quick action and process builder</description>
        <label>SMS Message</label>
        <length>800</length>
        <trackFeedHistory>false</trackFeedHistory>
        <trackHistory>false</trackHistory>
        <type>LongTextArea</type>
        <visibleLines>3</visibleLines>
    </fields>
    <fields>
        <fullName>Score1__c</fullName>
        <externalId>false</externalId>
        <formula>IF ( SDO_Sales_Know_Decision_Maker__c ,5,0)</formula>
        <formulaTreatBlanksAs>BlankAsZero</formulaTreatBlanksAs>
        <label>Decision Maker Score</label>
        <precision>18</precision>
        <required>false</required>
        <scale>2</scale>
        <trackHistory>false</trackHistory>
        <type>Number</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>Score2__c</fullName>
        <externalId>false</externalId>
        <formula>CASE(SDO_Sales_Decision_Timeframe__c  ,&quot;Immediately&quot;, 5, &quot;1-3 Months&quot;,4,&quot;3-6 Months&quot;, 3, &quot;6-12 Months&quot;, 2, &quot;Next Year&quot;, 1, 0)</formula>
        <formulaTreatBlanksAs>BlankAsZero</formulaTreatBlanksAs>
        <label>Decision Timeframe Score</label>
        <precision>18</precision>
        <required>false</required>
        <scale>2</scale>
        <trackHistory>false</trackHistory>
        <type>Number</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>Score3__c</fullName>
        <externalId>false</externalId>
        <formula>IF( SDO_Sales_Project_Defined__c = True, 5, 0)</formula>
        <formulaTreatBlanksAs>BlankAsZero</formulaTreatBlanksAs>
        <label>Project Defined Score</label>
        <precision>18</precision>
        <required>false</required>
        <scale>2</scale>
        <trackHistory>false</trackHistory>
        <type>Number</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>Score4__c</fullName>
        <externalId>false</externalId>
        <formula>IF(SDO_Sales_Has_Budget__c,5,0)</formula>
        <formulaTreatBlanksAs>BlankAsZero</formulaTreatBlanksAs>
        <label>Budget Score</label>
        <precision>18</precision>
        <required>false</required>
        <scale>2</scale>
        <trackHistory>false</trackHistory>
        <type>Number</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>Shadow_Roof_Type__c</fullName>
        <description>Used by the Einstein Vision Demo updated Jan 2020.</description>
        <inlineHelpText>Determines which image shows when you click the &quot;Analyze Roof Type&quot; button.  These are called &quot;RooftopFlat&quot; and &quot;RooftopPitched&quot; inside the static resource &quot;EinsteinVisionRooftopImages&quot;.</inlineHelpText>
        <label>Shadow Roof Type</label>
        <required>false</required>
        <trackFeedHistory>false</trackFeedHistory>
        <trackHistory>false</trackHistory>
        <type>Picklist</type>
        <valueSet>
            <restricted>true</restricted>
            <valueSetDefinition>
                <sorted>false</sorted>
                <value>
                    <fullName>Flat</fullName>
                    <default>false</default>
                    <label>Flat</label>
                </value>
                <value>
                    <fullName>Pitched</fullName>
                    <default>false</default>
                    <label>Pitched</label>
                </value>
            </valueSetDefinition>
        </valueSet>
    </fields>
    <fields>
        <fullName>Source__c</fullName>
        <externalId>false</externalId>
        <formula>IMAGE( URLsrc__c&amp;&quot;/servlet/servlet.ImageServer?id=&quot;&amp;CASE( LeadSource, 
&quot;Website&quot;,&quot;015Hu000005vDkQ&amp;oid=&quot;&amp;$Organization.Id,
&quot;Social Media&quot;, &quot;015Hu000005vDkR&amp;oid=&quot;&amp;$Organization.Id,
&quot;Marketing Event&quot;, &quot;015Hu000005vDkS&amp;oid=&quot;&amp;$Organization.Id,
&quot;Referral&quot;,&quot;015Hu000005vDkT&amp;oid=&quot;&amp;$Organization.Id,
&quot;Cold Call&quot;,&quot;015Hu000005vDkU&amp;oid=&quot;&amp;$Organization.Id,
&quot;Data.com&quot;, &quot;015Hu000005vDkV&amp;oid=&quot;&amp;$Organization.Id,
&quot;Community&quot;, &quot;015Hu000005vDkW&amp;oid=&quot;&amp;$Organization.Id,
&quot;Inbound Call&quot;,&quot;015Hu000005vDkX&amp;oid=&quot;&amp;$Organization.Id,
&quot;Partner&quot;,&quot;015Hu000005vDkY&amp;oid=&quot;&amp;$Organization.Id,
&quot;015Hu000005vDkQ&amp;oid=&quot;&amp;$Organization.Id),&quot;&quot;,22,22)</formula>
        <formulaTreatBlanksAs>BlankAsZero</formulaTreatBlanksAs>
        <label>Source</label>
        <required>false</required>
        <trackHistory>false</trackHistory>
        <type>Text</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>Status</fullName>
        <trackFeedHistory>false</trackFeedHistory>
        <trackHistory>false</trackHistory>
