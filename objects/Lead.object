    <fields>
        <fullName>Priority__c</fullName>
        <externalId>false</externalId>
        <formula>IMAGE( URLsrc__c&amp;&quot;/servlet/servlet.ImageServer?id=&quot;&amp;CASE( Rating,
&quot;Hot&quot;, &quot;015Hu000005vDkN&amp;oid=&quot;&amp;$Organization.Id,
&quot;Warm&quot;, &quot;015Hu000005vDkO&amp;oid=&quot;&amp;$Organization.Id,
&quot;Cool&quot;, &quot;015Hu000005vDkP&amp;oid=&quot;&amp;$Organization.Id,
&quot;015Hu000005vDkP&amp;oid=&quot;&amp;$Organization.Id),&quot;&quot;,22,22)</formula>
        <formulaTreatBlanksAs>BlankAsZero</formulaTreatBlanksAs>
        <label>Priority</label>
        <required>false</required>
        <trackHistory>false</trackHistory>
        <type>Text</type>
        <unique>false</unique>
    </fields>
