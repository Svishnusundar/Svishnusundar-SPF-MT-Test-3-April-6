                <value>
                    <fullName>Flat</fullName>
                    <default>false</default>
                    <label>Flat</label>
                </value>
                <value>
                    <fullName>Pitched</fullName>
                    <default>false</default>
                    <label>Pitched</label>
                </value>
            </valueSetDefinition>
        </valueSet>
    </fields>
