        <fullName>Roof_Type__c</fullName>
        <description>Used by the Einstein Vision Demo updated Jan 2020.  Set the Shadow_Roof_Type__c field to the value you want to be predicted in this field.</description>
        <inlineHelpText>This field will change automatically when you click the “Analyze Roof Type” button.</inlineHelpText>
        <label>Roof Type</label>
        <required>false</required>
        <trackFeedHistory>false</trackFeedHistory>
        <trackHistory>false</trackHistory>
        <type>Picklist</type>
        <valueSet>
            <restricted>true</restricted>
            <valueSetDefinition>
                <sorted>false</sorted>
                <value>
                    <fullName>Unknown</fullName>
