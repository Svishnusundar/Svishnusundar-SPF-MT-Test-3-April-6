    <fields>
        <fullName>Category</fullName>
        <inlineHelpText>Specifies the category of the item that&apos;s in custody.</inlineHelpText>
        <trackHistory>false</trackHistory>
        <type>Picklist</type>
    </fields>
    <fields>
        <fullName>CollectionDateTime</fullName>
        <inlineHelpText>The date and time when the custody item was collected.</inlineHelpText>
        <trackHistory>false</trackHistory>
    </fields>
    <fields>
        <fullName>Description</fullName>
        <inlineHelpText>The description of the item that&apos;s in custody.</inlineHelpText>
        <trackHistory>false</trackHistory>
    </fields>
    <fields>
