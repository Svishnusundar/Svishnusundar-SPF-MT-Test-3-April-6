        <type>Lookup</type>
    </fields>
    <fields>
        <fullName>Status</fullName>
        <inlineHelpText>Specifies the status of the item that&apos;s in custody.</inlineHelpText>
        <trackHistory>false</trackHistory>
        <type>Picklist</type>
    </fields>
    <fields>
        <fullName>gps_Type_of_Evidence__c</fullName>
        <label>Type of Evidence</label>
        <required>false</required>
        <trackHistory>false</trackHistory>
        <type>Picklist</type>
        <valueSet>
            <restricted>true</restricted>
            <valueSetDefinition>
                <sorted>false</sorted>
                <value>
                    <fullName>Physical</fullName>
                    <default>false</default>
                    <label>Physical</label>
                </value>
                <value>
                    <fullName>Digital</fullName>
                    <default>false</default>
                    <label>Digital</label>
                </value>
                <value>
                    <fullName>Biological</fullName>
                    <default>false</default>
                    <label>Biological</label>
                </value>
                <value>
                    <fullName>Documentary</fullName>
                    <default>false</default>
                    <label>Documentary</label>
                </value>
                <value>
                    <fullName>Other</fullName>
                    <default>false</default>
                    <label>Other</label>
                </value>
            </valueSetDefinition>
        </valueSet>
    </fields>
    <listViews>
