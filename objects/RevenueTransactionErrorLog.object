    <compactLayoutAssignment>SYSTEM</compactLayoutAssignment>
    <enableFeeds>false</enableFeeds>
    <externalSharingModel>Private</externalSharingModel>
    <listViews>
        <fullName>billing</fullName>
        <columns>RTEL.NAME</columns>
        <columns>RTEL.PRIMARY_RECORD</columns>
        <columns>RTEL.RELATED_RECORD</columns>
        <columns>RTEL.PRIMARY_RECORD_2</columns>
        <columns>RTEL.RELATED_RECORD_2</columns>
        <columns>RTEL.ERROR_CODE</columns>
        <columns>RTEL.ERROR_MESSAGE</columns>
        <columns>RTEL.CATEGORY</columns>
        <columns>RTEL.REQUEST_IDENTIFIER</columns>
        <filterScope>Everything</filterScope>
        <filters>
            <field>RTEL.CATEGORY</field>
            <operation>equals</operation>
            <value>IA,IBRSS,IBRPP,IBREHDS,IBRIG,IBRTP,IBRPOP,IBRS,IBRR,IRF,IBDTPR,IBDTPRSS,IBDPRTPP,IBRCA,ANILC,SCA,CI,VPI,IGF,CNILTC,IDP,IETC</value>
        </filters>
        <label>Billing Revenue Transaction Error Logs</label>
    </listViews>
    <listViews>
        <fullName>mine</fullName>
        <filterScope>Mine</filterScope>
        <label>My Revenue Transaction Error Logs</label>
    </listViews>
    <sharingModel>Private</sharingModel>
</CustomObject>
